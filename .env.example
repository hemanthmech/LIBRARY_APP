# ─────────────────────────────────────────────────────────────────────────────
# LibraTrack – Docker environment variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_DB=libratrack
POSTGRES_USER=libratrack
POSTGRES_PASSWORD=change-me-strong-password

# Optional: change the host port the app listens on (default 8000)
APP_PORT=8000
